# AI Provider: "bedrock" (AWS) or "gemini" (Google)
AI_PROVIDER=bedrock

# AWS Bedrock config
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
BEDROCK_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0

# Google Gemini config (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

GITHUB_TOKEN=your_github_token_optional
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# MongoDB — local or Atlas connection string
MONGO_URI=mongodb://localhost:27017/borne
PORT=3000

# Firebase Admin SDK — provide EITHER the path OR the JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SERVICE_ACCOUNT_JSON=
